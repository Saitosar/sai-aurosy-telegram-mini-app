# Frontend (Vite) - used at build time. Must match backend PORT.
VITE_API_BASE_URL=http://localhost:3001
# TON Connect: app URL for manifest (must match deployed URL).
# For production: set VITE_APP_URL in your deployment platform (Vercel, Netlify, etc.)
# or in .env.production. Otherwise manifest falls back to localhost.
# VITE_APP_URL=https://your-app.example.com
# TON Connect: return URL after wallet connection (e.g. https://t.me/YourBot/yourapp)
# VITE_TWA_RETURN_URL=https://t.me/YourBot/yourapp

# Backend (use 3001 when port 3000 is occupied by another app)
PORT=3001
# When set, proxy requests to SAI AUROSY platform instead of mock
# PLATFORM_API_URL=https://platform.example.com
# Used by platform for Telegram initData HMAC validation (platform-side)
# TELEGRAM_BOT_TOKEN=
