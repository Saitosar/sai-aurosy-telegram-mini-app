{
  "name": "sai-aurosy-telegram-mini-app",
  "private": true,
  "description": "SAI AUROSY Telegram Mini App - lightweight mobile control interface for robot operations",
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:clean": "lsof -ti:3001 -ti:3000 2>/dev/null | xargs kill -9 2>/dev/null; sleep 2; npm run dev",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run start:dev -w backend",
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "build:shared": "npm run build -w shared",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18"
  },
